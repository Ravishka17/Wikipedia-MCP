{
  "version": 2,
  "rewrites": [
    {
      "source": "/mcp",
      "destination": "/api/index"
    },
    {
      "source": "/sse",
      "destination": "/api/index"
    },
    {
      "source": "/messages",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist"
}
