# Wikipedia MCP Server — Environment Variables
# =============================================
#
# Copy this file to .env for local development.
# On Vercel, set these in the project's Environment Variables dashboard.

# ── Wikipedia language ────────────────────────────────────────────────────────

# Primary: Wikipedia language code.
# Common values: en, ja, es, de, fr, zh, zh-tw, ru, ar, it, pt, nl, pl, hi, ...
WIKIPEDIA_LANGUAGE=en

# Alternative: country/locale code — mapped automatically to the correct language.
# Examples: US, JP, CN, TW, DE, FR, ES, RU, SA, LK, IN, ...
WIKIPEDIA_COUNTRY=US

# ── Performance ───────────────────────────────────────────────────────────────

# Enable in-memory response cache (reduces Wikipedia API calls).
# Recommended for local dev; on Vercel each invocation is fresh so this has
# little effect in production.
ENABLE_CACHE=true

# ── Wikipedia bot authentication (optional) ───────────────────────────────────
# Obtain a bot password at https://en.wikipedia.org/wiki/Special:BotPasswords
# Format:  WIKIPEDIA_BOT_USERNAME = YourAccount@BotName
#          WIKIPEDIA_BOT_PASSWORD = the generated bot password
# Without these the server works anonymously (lower rate limits from Wikipedia).
WIKIPEDIA_BOT_USERNAME=
WIKIPEDIA_BOT_PASSWORD=

# ── Server ────────────────────────────────────────────────────────────────────
# Port for local development. Vercel ignores this.
PORT=8000

# ── Language examples ─────────────────────────────────────────────────────────
#
# English:              WIKIPEDIA_LANGUAGE=en   / WIKIPEDIA_COUNTRY=US
# Japanese:             WIKIPEDIA_LANGUAGE=ja   / WIKIPEDIA_COUNTRY=JP
# Chinese (Simplified): WIKIPEDIA_LANGUAGE=zh   / WIKIPEDIA_COUNTRY=CN
# Chinese (Traditional):WIKIPEDIA_LANGUAGE=zh-tw/ WIKIPEDIA_COUNTRY=TW
# Spanish:              WIKIPEDIA_LANGUAGE=es   / WIKIPEDIA_COUNTRY=ES
# German:               WIKIPEDIA_LANGUAGE=de   / WIKIPEDIA_COUNTRY=DE
# French:               WIKIPEDIA_LANGUAGE=fr   / WIKIPEDIA_COUNTRY=FR
# Arabic:               WIKIPEDIA_LANGUAGE=ar   / WIKIPEDIA_COUNTRY=SA
# Hindi:                WIKIPEDIA_LANGUAGE=hi   / WIKIPEDIA_COUNTRY=IN
# Sinhala:              WIKIPEDIA_LANGUAGE=si   / WIKIPEDIA_COUNTRY=LK
