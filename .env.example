# Wikipedia MCP Server Environment Variables
# ==========================================
# 
# These environment variables control which Wikipedia language edition
# the AI assistant will access. Perfect for MCP function calling!
#
# AI DEVELOPERS: Set these values to control Wikipedia language dynamically

# PRIMARY: Wikipedia Language Code
# Set this to control the Wikipedia language directly
# Common values: en, ja, es, de, fr, zh-hans, zh-tw, ru, ar, it, pt, nl, pl, etc.
WIKIPEDIA_LANGUAGE=en

# ALTERNATIVE: Country/Locale Code  
# AI-friendly way to set language (easier to remember than language codes)
# Examples: US, JP, CN, TW, DE, FR, ES, RU, SA, etc.
WIKIPEDIA_COUNTRY=US

# PERFORMANCE: Enable caching for faster AI responses
ENABLE_CACHE=true

# RATE LIMITING: Wikipedia API access token for high-volume AI usage
# Get this from: https://en.wikipedia.org/wiki/Special:BotPasswords
WIKIPEDIA_ACCESS_TOKEN=

# SERVER: Port configuration (Vercel will override this)
PORT=8000

# ==========================================
# AI LANGUAGE EXAMPLES:
# ==========================================
# 
# For English Wikipedia:
# WIKIPEDIA_LANGUAGE=en
# WIKIPEDIA_COUNTRY=US
#
# For Japanese Wikipedia:
# WIKIPEDIA_LANGUAGE=ja  
# WIKIPEDIA_COUNTRY=JP
#
# For Chinese Simplified (China):
# WIKIPEDIA_LANGUAGE=zh-hans
# WIKIPEDIA_COUNTRY=CN
#
# For Chinese Traditional (Taiwan):
# WIKIPEDIA_LANGUAGE=zh-tw
# WIKIPEDIA_COUNTRY=TW
#
# For Spanish Wikipedia:
# WIKIPEDIA_LANGUAGE=es
# WIKIPEDIA_COUNTRY=ES
#
# For German Wikipedia:
# WIKIPEDIA_LANGUAGE=de
# WIKIPEDIA_COUNTRY=DE
#
# For French Wikipedia:
# WIKIPEDIA_LANGUAGE=fr
# WIKIPEDIA_COUNTRY=FR
#
# For Russian Wikipedia:
# WIKIPEDIA_LANGUAGE=ru
# WIKIPEDIA_COUNTRY=RU
#
# For Arabic Wikipedia:
# WIKIPEDIA_LANGUAGE=ar
# WIKIPEDIA_COUNTRY=SA